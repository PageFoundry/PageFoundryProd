generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  RECEIVED // Angekommen
  IN_PROGRESS // Bearbeitung
  DONE // Fertig
}

enum ConsultationType {
  LANDING_PAGE // Landing Page Beratung
  SEO_AUDIT // SEO / Technical Audit
  CONTENT_COPY // Content & Copywriting
  ECOMMERCE_OPTIMIZATION // E-Commerce Optimierung
  FULL_SITE_REVIEW // Full-Website Assessment
  CONVERSION_OPT // Conversion-Optimierung
  SYSTEMS_AUTOMATION // Systeme / Automatisierung
  SPEED_AUDIT // Performance & Speed Audit
}

enum RetellProjectType {
  website
  redesign
  seo
  hosting
  web_app
  other
}

enum ClientStatus {
  LEAD
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ServiceBillingMode {
  ONE_TIME
  RECURRING
}

enum ClientServiceStatus {
  ACTIVE
  PAUSED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  BANK_TRANSFER
  STRIPE
  CASH
  OTHER
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  phone          String?
  passwordHash   String
  role           Role     @default(USER)
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())

  // OAuth-Profile
  provider   String? @db.VarChar(20)
  providerId String? @db.VarChar(191)
  name       String? @db.VarChar(191)
  avatarUrl  String? @db.VarChar(512)

  orders               Order[]
  consultationBookings ConsultationBooking[]
  passwordResetTokens  PasswordResetToken[]

  @@index([provider, providerId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique @db.Char(64)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Product {
  id            String  @id @default(cuid())
  name          String
  description   String
  priceCents    Int
  recurring     Boolean @default(false)
  recurringInfo String?
  restricted    Boolean @default(true)

  orders Order[]
}

model BusinessClient {
  id                  String       @id @default(cuid())
  name                String
  companyName         String?
  status              ClientStatus @default(ACTIVE)
  email               String?
  phone               String?
  website             String?
  billingName         String?
  billingEmail        String?
  billingAddressLine1 String?
  billingAddressLine2 String?
  postalCode          String?
  city                String?
  country             String       @default("DE")
  vatId               String?
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  contacts ClientContact[]
  services ClientService[]
  invoices Invoice[]

  @@index([status])
  @@index([name])
}

model ClientContact {
  id        String         @id @default(cuid())
  clientId  String
  client    BusinessClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean        @default(false)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([clientId])
  @@index([email])
}

model ServiceOffering {
  id             String             @id @default(cuid())
  name           String             @unique
  description    String?
  unitPriceCents Int
  taxRateBps     Int                @default(1900)
  billingMode    ServiceBillingMode @default(ONE_TIME)
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  clientServices ClientService[]
  invoiceItems   InvoiceItem[]

  @@index([isActive])
  @@index([billingMode])
}

model ClientService {
  id              String              @id @default(cuid())
  clientId        String
  client          BusinessClient      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         ServiceOffering?    @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  title           String
  quantity        Int                 @default(1)
  unitPriceCents  Int
  taxRateBps      Int                 @default(1900)
  billingInterval String              @default("monthly")
  status          ClientServiceStatus @default(ACTIVE)
  nextInvoiceDate DateTime?
  startedAt       DateTime            @default(now())
  cancelledAt     DateTime?
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([clientId])
  @@index([serviceId])
  @@index([status, nextInvoiceDate])
}

model Invoice {
  id                 String         @id @default(cuid())
  number             String         @unique
  clientId           String
  client             BusinessClient @relation(fields: [clientId], references: [id], onDelete: Restrict)
  status             InvoiceStatus  @default(DRAFT)
  issueDate          DateTime       @default(now())
  dueDate            DateTime
  servicePeriodStart DateTime?
  servicePeriodEnd   DateTime?
  currency           String         @default("EUR")
  subtotalCents      Int            @default(0)
  taxCents           Int            @default(0)
  totalCents         Int            @default(0)
  notes              String?
  sentAt             DateTime?
  paidAt             DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  items    InvoiceItem[]
  payments Payment[]

  @@index([clientId])
  @@index([status])
  @@index([issueDate])
  @@index([dueDate])
}

model InvoiceItem {
  id             String           @id @default(cuid())
  invoiceId      String
  invoice        Invoice          @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  serviceId      String?
  service        ServiceOffering? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  description    String
  quantity       Int              @default(1)
  unitPriceCents Int
  taxRateBps     Int              @default(1900)
  lineNetCents   Int
  lineTaxCents   Int
  lineGrossCents Int
  createdAt      DateTime         @default(now())

  @@index([invoiceId])
  @@index([serviceId])
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amountCents Int
  method      PaymentMethod @default(BANK_TRANSFER)
  reference   String?
  paidAt      DateTime      @default(now())
  createdAt   DateTime      @default(now())

  @@index([invoiceId])
  @@index([paidAt])
}

model Order {
  priceCents    Int         @default(0)
  id            String      @id @default(cuid())
  userId        String
  productId     String
  status        OrderStatus @default(RECEIVED)
  stripeSession String?
  createdAt     DateTime    @default(now())
  brief         Json?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model ConsultationSlot {
  id String @id @default(cuid())

  // Start/Ende des Slots
  start DateTime
  end   DateTime

  // einzelner Slot deaktiviert
  isDisabled Boolean @default(false)

  // final gebucht
  isBooked Boolean @default(false)

  // zukünftige Nutzung für temporäre Reservierungen
  temporaryReservedUntil DateTime?

  // Ein Slot kann höchstens einmal gebucht werden (DB-seitig erzwungen, s. slotId @unique)
  booking ConsultationBooking?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // unique statt index: verhindert doppelte Slots aus paralleler Lazy-Generierung
  @@unique([start])
  @@index([isBooked, temporaryReservedUntil])
}

model ConsultationBooking {
  id String @id @default(cuid())

  // unique: macht Doppelbuchung desselben Slots DB-seitig unmöglich
  slotId String           @unique
  slot   ConsultationSlot @relation(fields: [slotId], references: [id], onDelete: Restrict)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // für Hover-Historie
  email String @db.VarChar(320)

  // Teilnehmerzahl (Dropdown im Formular)
  participants Int @default(1)

  // Art der Beratung
  consultationType ConsultationType

  // Freitext-Beschreibung des Kunden
  description String

  // Zoom-Link zum Zeitpunkt der Buchung
  zoomUrl String @db.VarChar(512)

  // für spätere Stripe-Integration
  stripeSessionId       String? @db.VarChar(191)
  stripePaymentIntentId String? @db.VarChar(191)

  createdAt DateTime @default(now())

  @@index([email])
  @@index([stripeSessionId])
  @@index([stripePaymentIntentId])
}

model ConsultationDayOff {
  id String @id @default(cuid())

  // ganzer Tag ist deaktiviert (Feiertag, Urlaub, Krankheit)
  date DateTime

  reason String?

  createdAt DateTime @default(now())

  @@unique([date])
}

model CallLead {
  id                   String             @id @default(cuid())
  retellCallId         String?            @unique
  name                 String
  company              String?
  phone                String?
  reason               String
  projectType          RetellProjectType?
  appointmentRequested Boolean            @default(false)
  appointmentBooked    Boolean            @default(false)
  appointmentDateTime  DateTime?
  transcript           String?
  callStatus           String             @default("new")
  summary              String?
  noAppointmentReason  String?
  discordNotifiedAt    DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  calendarEvents CalendarEvent[]

  @@index([createdAt])
  @@index([appointmentBooked, appointmentDateTime])
}

model CalendarEvent {
  id            String   @id @default(cuid())
  leadId        String
  lead          CallLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  title         String
  description   String
  startDateTime DateTime
  endDateTime   DateTime
  timezone      String   @default("Europe/Berlin")
  status        String   @default("booked")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leadId])
  @@index([startDateTime, endDateTime])
  @@index([status])
}
