# Test-Umgebung. Wird NICHT versioniert (.gitignore: .env.*).
# Vollstaendig — scripts/test.sh laedt bewusst NICHT die Prod-.env, damit weder
# echte SMTP-Zugangsdaten noch Stripe-Keys je in einem Testprozess landen.
DATABASE_URL="postgresql://pagefoundry_user:PASSWORT@localhost:5432/pagefoundry_test"

# Mailversand hart aus (src/lib/email.ts wertet das aus).
EMAIL_ENABLED="false"
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_SECURE="false"
SMTP_USER="test"
SMTP_PASS="test"
EMAIL_FROM="test@example.com"
CONSULTATION_FROM_EMAIL="test@example.com"
CONSULTATION_ADMIN_EMAIL="admin@example.com"

JWT_SECRET="test-secret-not-used-in-production"
APP_BASE_URL="http://127.0.0.1:3011"
COOKIE_DOMAIN=""
NEXT_PUBLIC_ZOOM_URL="https://zoom.us/j/test"
DEFAULT_TIMEZONE="Europe/Berlin"

# Dummies: Module initialisieren diese Clients beim Import.
STRIPE_SECRET_KEY="sk_test_dummy"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_dummy"
STRIPE_WEBHOOK_SECRET_DASHBOARD="whsec_dummy"
STRIPE_WEBHOOK_SECRET_CLI="whsec_dummy"
STRIPE_PUBLIC_SUCCESS_URL="http://127.0.0.1:3011/success"
STRIPE_PUBLIC_CANCEL_URL="http://127.0.0.1:3011/cancel"
GOOGLE_CLIENT_ID="dummy"
GOOGLE_CLIENT_SECRET="dummy"
GOOGLE_REDIRECT_URL="http://127.0.0.1:3011/api/auth/google/callback"
RETELL_API_KEY="dummy"
DISCORD_WEBHOOK_URL=""

TEST_PORT="3011"
TEST_BASE_URL="http://127.0.0.1:3011"
