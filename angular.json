{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "social-audit": {
      "projectType": "application",
      "root": "src/social-audit",
      "sourceRoot": "src/social-audit",
      "prefix": "pf",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "public/social-audit-ui",
            "index": "src/social-audit/index.html",
            "browser": "src/social-audit/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.social-audit.json",
            "assets": [],
            "styles": ["src/social-audit/styles.css"],
            "scripts": [],
            "outputHashing": "none"
          },
          "configurations": {
            "production": {
              "optimization": true,
              "sourceMap": false,
              "namedChunks": false
            }
          },
          "defaultConfiguration": "production"
        }
      }
    }
  }
}
